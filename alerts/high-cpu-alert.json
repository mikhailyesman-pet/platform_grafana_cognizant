{
  "alert": {
    "title": "High CPU Usage",
    "description": "Alert when CPU usage exceeds 80% for 5 minutes",
    "condition": {
      "namespace": "AWS/EC2",
      "metricName": "CPUUtilization",
      "statistic": "Average",
      "period": 300,
      "threshold": 80,
      "comparisonOperator": "GreaterThanThreshold",
      "evaluationPeriods": 1
    },
    "alerting": {
      "enabled": true,
      "frequency": "1m",
      "handlerIds": [1],
      "name": "HighCPUUsage"
    },
    "notification": {
      "channels": ["grafana-alerts-sns"],
      "message": "CPU usage is {{ .Values.cpuUtilization }}% on instance {{ .Labels.InstanceId }}"
    }
  }
}
